# NILE BOOKING BACKEND PRODUCTION CONFIGURATION
NODE_ENV=production
PORT=5050
CLIENT_URL=https://nilebooking.co

# 1. DATABASE DEPENDENCY (MongoDB Atlas Cluster)
# Required for persistent merchant accounts, bookings, services, and staff
MONGODB_URI=mongodb+sandbox.mongodb.net/nilebooking?retryWrites=true&w=majority

# 2. AUTHENTICATION & SECURITY DEPENDENCY
# Secret key for signing JWT tokens for merchants & staff
JWT_SECRET=nile_super_secure_jwt_production_secret_2026_key

# 3. TRANSACTIONAL MAILING DEPENDENCY (Mailtrap / SendGrid / Amazon SES)
# Sends instant appointment confirmations & 24h client reminders
MAILTRAP_USER=your_smtp_username
MAILTRAP_PASS=your_smtp_password
MAILTRAP_FROM_EMAIL=noreply@nilebooking.co

# 4. CLOUD MEDIA STORAGE DEPENDENCY (Cloudinary)
# Required for uploading merchant logos, header banners, and bank transfer receipt screenshots
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# 5. WHATSAPP BUSINESS NOTIFICATION DEPENDENCY
# Automates rich WhatsApp booking confirmations & merchant alerts
WHATSAPP_API_URL=https://api.whatsapp.com/v1/messages
WHATSAPP_API_KEY=your_whatsapp_business_api_token

# 6. BANKING & ESCROW SETTLEMENT DEPENDENCY (Paystack / Providus)
PAYSTACK_SECRET_KEY=your_paystack_live_secret_key
PAYSTACK_MERCHANT_EMAIL=payments@nile.ng
PAYSTACK_MERCHANT_PHONE=+2348123843076
